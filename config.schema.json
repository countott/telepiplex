{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "category_folder": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "properties": {
          "kind": {"enum": ["live_action_movie", "animated_movie", "live_action_series", "animated_series"]},
          "name": {"type": "string", "minLength": 1},
          "path": {"type": "string", "pattern": "^/"},
          "plex_library_id": {"type": "string"}
        },
        "required": ["kind", "name", "path", "plex_library_id"],
        "additionalProperties": false
      }
    },
    "search": {"type": "object"},
    "metadata": {"type": "object"},
    "ai": {"type": "object"}
  },
  "required": ["category_folder", "search", "metadata", "ai"],
  "additionalProperties": false
}
