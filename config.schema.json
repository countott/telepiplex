{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "x-telepiplex-config-command": "config",
  "properties": {
    "base_url": {"type": "string", "pattern": "^https://"},
    "passport_url": {"type": "string", "pattern": "^https://"},
    "auth_mode": {"enum": ["direct", "scan"]},
    "access_token": {"type": "string", "writeOnly": true},
    "refresh_token": {"type": "string", "writeOnly": true},
    "app_id": {"type": "string"},
    "auth_poll_timeout": {"type": "number", "minimum": 30, "maximum": 900},
    "auth_poll_interval": {"type": "number", "minimum": 0.5, "maximum": 30},
    "timeout": {"type": "number", "minimum": 1, "maximum": 300},
    "download_timeout": {"type": "number", "minimum": 10, "maximum": 86400},
    "poll_interval": {"type": "number", "minimum": 0.1, "maximum": 300},
    "request_interval": {"type": "number", "minimum": 0, "maximum": 30},
    "save_directories": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "path": {"type": "string", "pattern": "^/"}
        },
        "required": ["name", "path"],
        "additionalProperties": false
      }
    }
  },
  "required": ["base_url", "passport_url", "auth_mode", "access_token", "refresh_token", "app_id", "auth_poll_timeout", "auth_poll_interval", "timeout", "download_timeout", "poll_interval", "request_interval", "save_directories"],
  "additionalProperties": false
}
