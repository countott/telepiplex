# Telegram-115Bot配置文件, 请检查所有必填项目，如不填会影响机器人正常运行

############################################日志设置##################################
# log_level （必填）
# 日志级别
# debug|info|warning|error|critical
log_level: info
############################################Telegram设置##################################
# bot token （必填）
# 机器人唯一Token，如果没有@BotFather创建
bot_token: your_bot_token

# allowed_user （必填）
# 授权可以使用该bot的user_id，可以通过@getidsbot获取
# 数字类型不要引号
allowed_user: your_user_id

# 机器人名称 例如：@your_bot_name 
# 非必填，转存视频需要
bot_name: "@your_bot_name"

# telegram 的api信息 
# 非必填，转存视频需要
tg_api_id: your_tg_api_id
tg_api_hash: your_tg_api_hash

############################################115开放平台##################################
# 115_app_id 
# 申请地址https://open.115.com/
# 如已填写115_app_id, access_token,refresh_token可留空！
115_app_id: your_115_app_id

# 如没有115_app_id，请填写access_token和refresh_token！
# 115_app_id和token不能同时为空！！！
access_token: your_access_token
refresh_token: your_refresh_token

#############################################115离线下载设置###################################
# 下载完成后自动删除文件夹中的广告文件
clean_policy:
  # 是否开启自动清理 on: 开启 off: 关闭
  # 当设置为off时，所有策略不会生效，默认为开启
  switch: "on"
  # 文件小于设置值则自动删除单位K,M,G
  less_than: 400M

# 设置分类文件夹
# 分类文件夹设置只针对离线任务，离线下载完成后，会弹出需要移动到的分类文件夹，可以设置多个
category_folder:
  # 电影下的分类目录，不能修改
  - name: movies
    # 选择保存目录的第一级分类目录，不建议修改
    display_name: 电影
    # 一级分类目录(电影)下的二级分类，可按需修改或添加
    path_map:
        # 显示名称，可按需修改
      - name: 外语电影
        # 对应115上的完整路径，可以按需修改
        path: /影视/电影/外语电影
      - name: 华语电影
        path: /影视/电影/华语电影
      - name: 动画电影
        path: /影视/电影/动画电影
#############################################搜索设置#######################################
# 通过Prowlarr搜索片源，选择候选后复用上面的分类目录投递到115离线下载
search:
  enable: false
  prowlarr:
    base_url: "http://192.168.7.7:9696"
    api_key: ""
    timeout: 20
    indexer_ids: "-2"
    categories:
      movie: 2000
      tv: 5000
    result_limit: 8
  scoring:
    prefer_resolution:
      - "2160p"
      - "1080p"
    prefer_source:
      - "WEB-DL"
      - "BluRay"
      - "Remux"
    prefer_codec:
      - "HEVC"
      - "H.265"
      - "x265"
      - "H.264"
      - "x264"
    prefer_audio:
      - "Atmos"
      - "TrueHD"
      - "DTS-HD"
      - "EAC3"
    reject_keywords:
      - "CAM"
      - "TS"
      - "TC"
      - "枪版"
      - "抢先"
      - "HC"
      - "HDTC"
      - "HDCAM"

#############################################媒体库设置####################################
media:
  # 自动整理失败或缺少元数据时移入的115目录
  unorganized_path: /未整理
  # Plex配置预留。配置完整时优先走Plex链路；当前仅保留扫库入口，不触发实际接口。
  plex:
    base_url: ""
    token: ""
    library_id: ""
  # Emby配置。仅在未配置Plex且Emby配置完整时创建STRM并通知扫库。
  emby:
    base_url: ""
    api_key: ""
    strm_mode: disable
    strm_root: /media/115
    openlist_root: /115
    mount_root: /CloudNAS/115

##########################################Aria2#######################################
# 设置Aria2可选择将离线的影片推送到Aria2
# 默认关闭
aria2:
  # 是否启用
  enable: false
  # 指定设备名称, 例如“我的群晖”，“我的飞牛”
  device_name: 我的飞牛
  # Arai2地址 http(s)://your_aria2_host
  host: http://your_aria2_host
  # Aria2 RPC端口
  port: 6800
  # Aria2 密钥
  rpc_secret: your_aria2_rpc_secret
  # 下载目录 (Aari2容器中的下载位置)
  download_path: "/Downloads"
  ##########################################AI#######################################
# AI支持
ai:
  # 请求地址
  api_url: https://api.siliconflow.cn/v1
  # api_key
  api_key: sk-xxxxxxxxxxxxxxxxxxx
  # 模型
  model: deepseek-ai/DeepSeek-V3.2
