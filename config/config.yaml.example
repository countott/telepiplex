# Telepiplex feature/115 配置模板；运行时配置路径为 /config/config.yaml。

# 基础日志：可选 debug / info / warning / error / critical。
log_level: info

# Telegram Bot。
bot_token: "your_bot_token"
allowed_user: 123456789

# 115 授权：OpenAPI 填 115_app_id，直连 Token 填 access_token / refresh_token。
115_app_id: null
access_token: ""
refresh_token: ""

# 115 OpenAPI：请求超时秒数。
open115:
  timeout: 30

# 清理策略：下载完成后按体积清理广告小文件。
clean_policy:
  switch: "on"
  less_than: 400M

# 保存目录：path 是 115 网盘内的保存目录。
category_folder:
  - name: 电影
    path: /电影
  - name: 剧集
    path: /剧集
