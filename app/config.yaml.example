# Telepiplex Plex Feature 核心配置模板；运行时配置路径为 /config/config.yaml。

log_level: info

bot_token: "your_bot_token"
allowed_user: 123456789

# 四类媒体目录合同；Plex 业务参数见 config/modules/plex-management.yaml.example。
category_folder:
  - kind: live_action_movie
    name: 真人电影
    path: /真人电影
    plex_library_id: ""
  - kind: animated_movie
    name: 动画电影
    path: /动画电影
    plex_library_id: ""
  - kind: live_action_series
    name: 真人剧集
    path: /真人剧集
    plex_library_id: ""
  - kind: animated_series
    name: 动画剧集
    path: /动画剧集
    plex_library_id: ""
