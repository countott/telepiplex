# Telepiplex 配置模板；运行时配置路径为 /config/config.yaml。

log_level: info

bot_token: "your_bot_token"
allowed_user: 123456789

modules:
  enabled: all
  disabled: []

# 共享保存目录合同。115 和媒体搜索模块会复用该结构。
category_folder:
  - name: 真人电影
    path: /真人电影
  - name: 动画电影
    path: /动画电影
  - name: 真人剧集
    path: /真人剧集
  - name: 动画剧集
    path: /动画剧集
