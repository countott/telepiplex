# Telepiplex Media Search 配置模板；运行时配置路径为 /config/config.yaml。

log_level: info

bot_token: "your_bot_token"
allowed_user: 123456789

category_folder:
  - name: 真人电影
    path: /真人电影
  - name: 动画电影
    path: /动画电影
  - name: 真人剧集
    path: /真人剧集
  - name: 动画剧集
    path: /动画剧集

search:
  enable: false
  prowlarr:
    base_url: "http://your-prowlarr:9696"
    api_key: ""
    timeout: 150
    indexer_ids: "-2"
    categories:
      movie: 2000
      tv: 5000
    result_limit: 8
  scoring:
    prefer_resolution:
      - "2160p"
      - "1080p"
    prefer_source:
      - "WEB-DL"
      - "BluRay"
      - "Remux"
    prefer_codec:
      - "HEVC"
      - "H.265"
      - "x265"
      - "H.264"
      - "x264"
    prefer_audio:
      - "Atmos"
      - "TrueHD"
      - "DTS-HD"
      - "EAC3"
    reject_keywords:
      - "CAM"
      - "TS"
      - "TC"
      - "枪版"
      - "抢先"
    keyword_scores:
      "2160p": 35
      "1080p": 25
      "WEB-DL": 25
      "BluRay": 22
      "Remux": 24
      "中字": 8
      "CAM": -90
    indexer_scores:
      "M-Team": 30
      "TorrentLeech": 10

metadata:
  tvdb:
    enable: false
    base_url: "https://api4.thetvdb.com/v4"
    api_key: ""
    subscriber_pin: ""
    timeout: 15

ai:
  api_url: ""
  api_key: ""
  model: ""
  timeout: 60
